{
    "name": "@ziorweb-dev/product-selector",
    "version": "0.0.1",
    "description": "Reusable WordPress product selector component",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts",
        "dev": "tsup src/index.ts --watch --format esm,cjs --dts"
    },
    "peerDependencies": {
        "@wordpress/components": ">=32",
        "@wordpress/element": ">=6",
        "@wordpress/i18n": ">=6",
        "@wordpress/api-fetch": ">=7"
    },
    "devDependencies": {
        "@wordpress/components": "^32.1.0",
        "@wordpress/element": "^6.41.0",
        "@wordpress/i18n": "^6.14.0",
        "@wordpress/api-fetch": "^7.41.0",
        "@types/react": "^18.0.0",
        "typescript": "^5.6.0",
        "tsup": "^8.0.0"
    }
}