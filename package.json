{
    "name": "@ziorweb-dev/product-selector",
    "version": "0.1.8",
    "description": "Reusable WordPress product selector component",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ZIORWebDev/product-selector.git"
    },
    "homepage": "https://github.com/ZIORWebDev/product-selector#readme",
    "bugs": {
        "url": "https://github.com/ZIORWebDev/product-selector/issues"
    },
    "keywords": [
        "wordpress",
        "gutenberg",
        "component",
        "product-selector"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "default": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "scripts": {
        "build": "rimraf dist && webpack && tsc -p tsconfig.build.json",
        "dev": "webpack --watch --mode development",
        "prepublishOnly": "npm run build",
        "deploy": "npm publish"
    },
    "peerDependencies": {
        "@wordpress/api-fetch": ">=7",
        "@wordpress/components": ">=32",
        "@wordpress/element": ">=6",
        "@wordpress/i18n": ">=6"
    },
    "devDependencies": {
        "@types/react": "^18.0.0",
        "@wordpress/api-fetch": "^7.41.0",
        "@wordpress/components": "^32.1.0",
        "@wordpress/element": "^6.41.0",
        "@wordpress/i18n": "^6.14.0",
        "rimraf": "^6.1.3",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "webpack": "^5.105.4",
        "webpack-cli": "^6.0.1"
    }
}